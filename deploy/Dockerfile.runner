# 执行机 runner 镜像（可选形态——裸机 pm2 部署 runner 同样受支持，
# NPU 机器上跑真实训练/测试时通常直接用宿主环境 + pm2）。
# 认证：Claude 挂载 ~/.claude（OAuth）或传 ANTHROPIC_API_KEY / ANTHROPIC_AUTH_TOKEN；
# Codex 需镜像/宿主 PATH 上有 codex CLI，并挂载 ~/.codex 或按单次运行注入 CODEX_API_KEY。
#
#   docker build -f deploy/Dockerfile.runner \
#     --build-arg http_proxy=$http_proxy --build-arg https_proxy=$https_proxy \
#     -t co-runner:latest .

FROM node:22-slim AS build
ARG http_proxy
ARG https_proxy
ENV http_proxy=${http_proxy} https_proxy=${https_proxy} \
    CI=1 COREPACK_ENABLE_DOWNLOAD_PROMPT=0
RUN corepack enable && corepack prepare pnpm@11.9.0 --activate

WORKDIR /app
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages/protocol/package.json packages/protocol/
COPY packages/server/package.json packages/server/
COPY packages/runner/package.json packages/runner/
COPY packages/web/package.json packages/web/
RUN pnpm install --frozen-lockfile

COPY packages ./packages
COPY tsconfig.base.json ./

FROM node:22-slim
RUN apt-get update && apt-get install -y --no-install-recommends git ca-certificates \
  && rm -rf /var/lib/apt/lists/*
ENV NODE_ENV=production
WORKDIR /app
COPY --from=build /app/package.json /app/pnpm-workspace.yaml ./
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/tsconfig.base.json ./
COPY --from=build /app/packages/protocol ./packages/protocol
COPY --from=build /app/packages/runner ./packages/runner

# SERVER_URL / RUNNER_SHARED_TOKEN / MACHINE_ID / MACHINE_LABELS / CODE_SERVER_URL 经环境变量注入
CMD ["node_modules/.bin/tsx", "packages/runner/src/index.ts"]
