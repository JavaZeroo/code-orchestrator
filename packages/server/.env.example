DATABASE_URL=postgres://co:co@localhost:5432/co
# 8080 被宿主机已有服务占用（host 网络），用 7620
PORT=7620
HOST=0.0.0.0
RUNNER_SHARED_TOKEN=dev-runner-token
# openssl rand -hex 32 生成；会话签名与 token 加密的密钥源
AUTH_SECRET=
PUBLIC_URL=http://localhost:7620

# 自动工作区供给（需求→PR 无人值守）：设置后每个 run 分配独立 git worktree（落本地盘）
# 单机部署用；多机需改为 runner 侧供给。不设则沿用触发器静态 cwd。
WORKSPACE_ROOT=/var/lib/co/workspaces
WORKSPACE_GIT_PROXY=
WORKSPACE_GIT_NAME=code-orchestrator
WORKSPACE_GIT_EMAIL=co@localhost
