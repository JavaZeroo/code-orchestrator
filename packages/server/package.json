    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@co/protocol": "workspace:*",
    "@fastify/cors": "^11.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.0.0",
    "@paralleldrive/cuid2": "^2.2.2",
    "better-auth": "^1.3.0",
    "croner": "^10.0.1",
    "drizzle-orm": "^0.44.0",
    "fastify": "^5.0.0",
    "postgres": "^3.4.0",
    "tsx": "^4.19.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.9.3"
  }
}
